generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Org {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  members   OrgMember[]
  entities  Entity[]
  auditLogs AuditLog[]
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      String   @default("member") // owner|admin|member
  createdAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id])
  @@unique([orgId, userId])
}

model Entity {
  id        String   @id @default(cuid())
  orgId     String
  rut       String
  legalName String
  address   String?
  createdAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id])
  cases     DelegationCase[]
  @@unique([orgId, rut])
}

model DelegationCase {
  id        String   @id @default(cuid())
  entityId  String
  status    String   @default("draft") // draft|approved|exported|sent
  version   Int      @default(1)

  delegateFullName         String?
  delegateRut              String?
  delegateAddress          String?
  delegateEmailInstitutional String?
  delegatePhone            String?

  subrogantEmailInstitutional String?

  legalLinkType            String? // contrato|acto|acuerdo|otro
  legalLinkReference       String?

  orgPosition              String?
  representationPowerDesc  String?

  deadlineFeb15Ack         Boolean  @default(false)

  approvedBy   String?
  approvedAt   DateTime?

  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entity       Entity   @relation(fields: [entityId], references: [id])
  checklist    ChecklistItem[]
  evidence     EvidenceFile[]
  documents    GeneratedDocument[]
}

model ChecklistItem {
  id          String   @id @default(cuid())
  caseId      String
  key         String
  title       String
  description String?
  required    Boolean  @default(true)
  status      String   @default("todo") // todo|done|blocked
  completedAt DateTime?
  completedBy String?
  evidenceId  String?

  case        DelegationCase @relation(fields: [caseId], references: [id])
  @@unique([caseId, key])
}

model EvidenceFile {
  id         String   @id @default(cuid())
  caseId     String
  storageUrl String   // por ahora URL pública o signed
  filename   String
  mime       String
  size       Int
  uploadedBy String?
  uploadedAt DateTime @default(now())

  case       DelegationCase @relation(fields: [caseId], references: [id])
}

model GeneratedDocument {
  id         String   @id @default(cuid())
  caseId     String
  version    Int
  docType    String   // designation_pdf
  storageUrl String
  createdBy  String?
  createdAt  DateTime @default(now())

  case       DelegationCase @relation(fields: [caseId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  entityId  String?
  caseId    String?
  actorId   String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  org       Org      @relation(fields: [orgId], references: [id])
}
